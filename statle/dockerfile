# ---------- Build backend ----------
FROM mcr.microsoft.com/dotnet/sdk:10.0-preview AS backend-build
WORKDIR /src/Api

COPY Api/*.csproj ./
RUN dotnet restore

COPY Api/. ./
RUN dotnet publish -c Release -o /out

# ---------- Build frontend ----------
FROM node:20 AS frontend-build
WORKDIR /src/app

COPY package*.json ./
RUN npm install

COPY . ./
RUN npm run build

# ---------- Final image ----------
FROM mcr.microsoft.com/dotnet/aspnet:10.0-preview
WORKDIR /app

RUN apt-get update && apt-get install -y nodejs npm

# backend
COPY --from=backend-build /out ./backend

# frontend (place at container root `/app` — your project uses `app` folder)
COPY --from=frontend-build /src/app ./

EXPOSE 5055
EXPOSE 3303

CMD bash -c "dotnet ./backend/Api.dll --urls http://0.0.0.0:5055 & cd /app && npm start -- --hostname 0.0.0.0 --port 3303"